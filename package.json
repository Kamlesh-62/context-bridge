{
  "name": "context-bridge-mcp",
  "version": "1.0.6",
  "type": "module",
  "description": "Shared project memory for Claude Code, Codex, and Gemini CLI via MCP. Simple markdown-based storage.",
  "license": "MIT",
  "author": "Kamlesh Prajapati",
  "homepage": "https://github.com/Kamlesh-62/context-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kamlesh-62/context-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/Kamlesh-62/context-bridge/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/server/index.js",
  "bin": {
    "context-bridge": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist/",
    "examples/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "memory",
    "claude",
    "codex",
    "gemini",
    "ai",
    "context",
    "model-context-protocol",
    "context-bridge",
    "markdown"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
